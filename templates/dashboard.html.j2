<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>I4C Threat Analytics Dashboard - {{ batch_id }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Fraunces:opsz,wght@9..144,600;9..144,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="assets/style.css">
</head>
<body class="dashboard-page">
  <div class="dashboard-orb orb-one"></div>
  <div class="dashboard-orb orb-two"></div>
  <div class="dashboard-shell">
    <header class="dashboard-hero">
      <div class="hero-copy">
        <div class="brand-lockup">
          <img class="org-logo" src="{{ logo_path }}" alt="Indian Cyber Crime Coordination Centre logo">
          <div class="brand-copy">
            <p class="eyebrow">Indian Cyber Crime Coordination Centre</p>
            <h1>Threat Analytics Domain Intelligence Desk</h1>
            <p class="header-copy">
              Investigative dashboard for batch <strong>{{ batch_id }}</strong>. This deployment consolidates passive intelligence,
              evidence capture, legal triage, APNIC attribution, and packaged artefacts for operational review and partner sharing.
            </p>
          </div>
        </div>
        <div class="hero-meta">
          <span class="meta-pill">Generated {{ generated_at_utc }}</span>
          <span class="meta-pill">Published case set {{ total_domains }} domains</span>
          <span class="meta-pill">Static GitHub Pages deployment</span>
        </div>
      </div>

      <aside class="hero-command">
        <p class="command-kicker">Case Exports</p>
        <h2>Operational download set</h2>
        <p class="command-copy">
          Export the consolidated CSV for spreadsheet review or pull the evidence package to obtain raw JSON,
          HTML/PDF reports, manifests, and screenshots outside the dashboard.
        </p>
        <div class="hero-actions">
          <a class="button secondary" href="{{ domains_csv_path }}" download>Download Full CSV</a>
          <a class="button primary" href="{{ all_evidence_zip_path }}" download>Download Evidence Package</a>
        </div>
      </aside>
    </header>

    <section class="stats-grid" id="summary-cards">
      <article class="stats-card">
        <span class="label">Total Domains</span>
        <strong id="stat-total">0</strong>
        <p class="stat-note">Published records in the current case set.</p>
      </article>
      <article class="stats-card">
        <span class="label">Active Malicious</span>
        <strong id="stat-active">0</strong>
        <p class="stat-note">Domains with live captures and non-benign assessment.</p>
      </article>
      <article class="stats-card">
        <span class="label">Inactive / Down</span>
        <strong id="stat-inactive">0</strong>
        <p class="stat-note">Targets that did not expose a working service during capture.</p>
      </article>
      <article class="stats-card">
        <span class="label">Unique IPs</span>
        <strong id="stat-ips">0</strong>
        <p class="stat-note">Distinct resolved infrastructure footprint.</p>
      </article>
      <article class="stats-card">
        <span class="label">Unique Registrars</span>
        <strong id="stat-registrars">0</strong>
        <p class="stat-note">Registration providers represented in the batch.</p>
      </article>
      <article class="stats-card">
        <span class="label">Category Spread</span>
        <strong id="stat-categories">0</strong>
        <p class="stat-note">Distinct analytical categories assigned across the batch.</p>
      </article>
    </section>

    <section class="briefing-grid">
      <article class="panel panel-feature">
        <div class="panel-header">
          <div>
            <p class="panel-kicker">Executive Brief</p>
            <h2>Batch highlights</h2>
          </div>
        </div>
        <div class="briefing-list" id="headline-insights"></div>
      </article>

      <article class="panel">
        <div class="panel-header">
          <div>
            <p class="panel-kicker">Severity</p>
            <h2>Distribution of assessed risk</h2>
          </div>
        </div>
        <canvas id="severity-chart" aria-label="Severity distribution chart"></canvas>
      </article>

      <article class="panel">
        <div class="panel-header">
          <div>
            <p class="panel-kicker">Threat Typology</p>
            <h2>Category concentration</h2>
          </div>
        </div>
        <canvas id="category-chart" aria-label="Threat category chart"></canvas>
      </article>

      <article class="panel">
        <div class="panel-header">
          <div>
            <p class="panel-kicker">Hosting Geography</p>
            <h2>Top observed regions</h2>
          </div>
        </div>
        <canvas id="country-chart" aria-label="Hosting country chart"></canvas>
      </article>

      <article class="panel">
        <div class="panel-header">
          <div>
            <p class="panel-kicker">Impersonation</p>
            <h2>Top targeted brands</h2>
          </div>
        </div>
        <table class="dashboard-table compact">
          <thead>
            <tr><th>Brand</th><th>Count</th></tr>
          </thead>
          <tbody id="brands-table-body"></tbody>
        </table>
      </article>

      <article class="panel" id="holders-panel">
        <div class="panel-header">
          <div>
            <p class="panel-kicker">Attribution</p>
            <h2>Top allocation holders</h2>
          </div>
        </div>
        <table class="dashboard-table compact">
          <thead>
            <tr><th>Holder</th><th>Count</th></tr>
          </thead>
          <tbody id="holders-table-body"></tbody>
        </table>
      </article>
    </section>

    <section class="panel">
      <div class="panel-header">
        <div>
          <p class="panel-kicker">Shared Infrastructure</p>
          <h2>Operational clustering</h2>
        </div>
        <p class="panel-note">Clusters highlight repeated hosting, registrar, visual, and holder signals that may support larger campaign linkage.</p>
      </div>
      <table class="dashboard-table compact">
        <thead>
          <tr>
            <th>Shared Indicator</th>
            <th>Type</th>
            <th>Cluster Size</th>
            <th>Domains</th>
          </tr>
        </thead>
        <tbody id="cluster-table-body"></tbody>
      </table>
    </section>

    <section class="panel domain-panel">
      <div class="panel-header">
        <div>
          <p class="panel-kicker">Analytical Corpus</p>
          <h2>Domain review table</h2>
        </div>
        <div class="mini-actions">
          <a class="button ghost" href="{{ domains_csv_path }}" download>Download Full CSV</a>
          <a class="button ghost" href="{{ all_evidence_zip_path }}" download>Download Evidence Package</a>
        </div>
      </div>
      <div class="filter-bar">
        <input type="search" id="search-input" placeholder="Search domain, brand, registrar, holder, payment rail">
        <select id="severity-filter">
          <option value="">All severities</option>
        </select>
        <select id="category-filter">
          <option value="">All categories</option>
        </select>
        <select id="country-filter">
          <option value="">All countries</option>
        </select>
        <input type="date" id="date-from-filter">
        <input type="date" id="date-to-filter">
      </div>
      <div class="table-wrap">
        <table class="dashboard-table" id="domains-table">
          <thead>
            <tr>
              <th><button type="button" class="sort-button" data-sort="domain">Domain</button></th>
              <th><button type="button" class="sort-button" data-sort="severity">Severity</button></th>
              <th><button type="button" class="sort-button" data-sort="category">Category</button></th>
              <th><button type="button" class="sort-button" data-sort="vt_malicious">VT Score</button></th>
              <th><button type="button" class="sort-button" data-sort="registered">Reg Date</button></th>
              <th><button type="button" class="sort-button" data-sort="allocation_holder">APNIC Holder</button></th>
              <th><button type="button" class="sort-button" data-sort="apnic_region">APNIC Region</button></th>
              <th><button type="button" class="sort-button" data-sort="status">Status</button></th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="domains-table-body"></tbody>
        </table>
      </div>
    </section>

    <footer class="dashboard-footer">
      <div>
        <p class="footer-title">Indian Cyber Crime Coordination Centre</p>
        <p class="footer-copy">Analyst-facing static publication of the current batch. Legal classification and clustering outputs remain subject to supervisory and partner review before operational use.</p>
      </div>
      <div class="footer-actions">
        <a class="button ghost" href="{{ domains_csv_path }}" download>Download Full CSV</a>
        <a class="button primary" href="{{ all_evidence_zip_path }}" download>Download Evidence Package</a>
      </div>
    </footer>
  </div>

  <script>
    window.DOMAIN_ANALYSER_CONFIG = {
      summaryJsonPath: "{{ summary_json_path }}",
      domainsJsonPath: "{{ domains_json_path }}",
      domainsCsvPath: "{{ domains_csv_path }}",
      allEvidenceZipPath: "{{ all_evidence_zip_path }}"
    };
  </script>
  <script src="{{ chart_js_url }}" onerror="var s=document.createElement('script');s.src='assets/chart.min.js';document.head.appendChild(s);"></script>
  <script src="assets/dashboard.js"></script>
</body>
</html>
