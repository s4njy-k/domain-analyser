<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ report.domain }} - NCTAU Domain Analysis Report</title>
  <style>{{ style_css }}</style>
  <style>
    @page {
      size: A4;
      margin: 16mm 12mm 18mm;
      @top-left {
        content: "NCTAU / I4C Domain Analysis Draft";
        color: #475569;
        font-size: 9pt;
      }
      @top-right {
        content: "{{ report_identifier }}";
        color: #475569;
        font-size: 9pt;
      }
      @bottom-left {
        content: "{{ report_disclaimer }}";
        color: #64748b;
        font-size: 8pt;
      }
      @bottom-right {
        content: "Page " counter(page) " of " counter(pages);
        color: #475569;
        font-size: 9pt;
      }
    }

    .report-page {
      background: #e7edf4;
      color: #10233c;
      min-height: 100vh;
      font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
    }

    .report-shell {
      max-width: 1320px;
      margin: 0 auto;
      padding: 24px;
    }

    .cover-page {
      position: relative;
      overflow: hidden;
      min-height: calc(100vh - 48px);
      margin-bottom: 20px;
      padding: 44px 42px;
      background:
        radial-gradient(circle at top right, rgba(186, 147, 76, 0.14), transparent 26%),
        linear-gradient(160deg, #0d2036 0%, #17365f 52%, #234d7f 100%);
      color: #f8fbff;
      border-radius: 24px;
      box-shadow: 0 24px 60px rgba(15, 23, 42, 0.22);
      border: 1px solid rgba(255, 255, 255, 0.08);
      page-break-after: always;
    }

    .cover-page::before {
      content: "";
      position: absolute;
      inset: auto -120px -120px auto;
      width: 360px;
      height: 360px;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: radial-gradient(circle, rgba(255, 255, 255, 0.06), transparent 65%);
    }

    .cover-page::after {
      content: "NCTAU";
      position: absolute;
      right: 42px;
      bottom: 24px;
      font-family: Georgia, "Times New Roman", serif;
      font-size: 5.5rem;
      letter-spacing: 0.08em;
      color: rgba(255, 255, 255, 0.06);
      font-weight: 700;
    }

    .cover-page h1,
    .cover-strip h1,
    .section-card h2 {
      font-family: Georgia, "Times New Roman", serif;
    }

    .cover-kicker {
      margin: 0 0 18px;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.22em;
      color: rgba(255, 255, 255, 0.78);
    }

    .cover-lead {
      max-width: 760px;
      margin: 0 0 26px;
      color: rgba(248, 251, 255, 0.9);
      line-height: 1.8;
      font-size: 1.02rem;
    }

    .cover-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.6fr) minmax(280px, 0.9fr);
      gap: 22px;
      position: relative;
      z-index: 1;
    }

    .cover-panel {
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 18px;
      padding: 18px 20px;
      backdrop-filter: blur(2px);
    }

    .cover-panel dl {
      margin: 0;
      display: grid;
      gap: 14px;
    }

    .cover-panel dt {
      margin-bottom: 4px;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255, 255, 255, 0.72);
    }

    .cover-panel dd {
      margin: 0;
      font-size: 1rem;
      font-weight: 700;
      word-break: break-word;
    }

    .cover-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 18px;
    }

    .report-hero,
    .section-card,
    .cover-strip,
    .summary-matrix {
      background: #fff;
      border-radius: 18px;
      box-shadow: 0 18px 36px rgba(15, 23, 42, 0.12);
      border: 1px solid rgba(15, 23, 42, 0.08);
    }

    .report-hero {
      overflow: hidden;
      margin-bottom: 18px;
    }

    .cover-strip {
      display: grid;
      grid-template-columns: minmax(0, 2fr) minmax(260px, 1fr);
      gap: 18px;
      padding: 24px;
      background:
        radial-gradient(circle at top left, rgba(186, 147, 76, 0.12), transparent 32%),
        linear-gradient(135deg, #10243d, #17365f 58%, #27568d);
      color: #f8fbff;
      border: 0;
      box-shadow: none;
      border-radius: 18px 18px 0 0;
      position: relative;
    }

    .cover-strip h1 {
      margin: 0 0 10px;
      font-size: clamp(2rem, 3vw, 2.8rem);
      line-height: 1.1;
    }

    .cover-strip p {
      margin: 0 0 8px;
      line-height: 1.6;
    }

    .cover-meta {
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 16px;
      padding: 16px;
      align-self: stretch;
    }

    .cover-meta dl {
      margin: 0;
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .cover-meta dt {
      font-size: 0.74rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.75);
      margin-bottom: 4px;
    }

    .cover-meta dd {
      margin: 0;
      font-weight: 700;
      word-break: break-word;
    }

    .hero-toolbar {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
      padding: 16px 24px 20px;
      background: #f7f9fc;
      border-top: 1px solid rgba(15, 23, 42, 0.08);
    }

    .disclaimer-banner {
      border-radius: 14px;
      background: #fff8de;
      color: #7a4a00;
      border: 1px solid rgba(184, 134, 11, 0.35);
      padding: 12px 14px;
      font-size: 0.93rem;
      line-height: 1.6;
      flex: 1 1 420px;
    }

    .summary-matrix {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1px;
      overflow: hidden;
      margin-bottom: 18px;
      background: rgba(15, 23, 42, 0.08);
    }

    .summary-matrix article {
      padding: 16px 18px;
      background: #fff;
    }

    .summary-matrix .label {
      display: block;
      margin-bottom: 8px;
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #64748b;
    }

    .summary-matrix strong {
      display: block;
      font-size: 1.2rem;
      word-break: break-word;
    }

    .section-card {
      padding: 22px;
      margin-bottom: 18px;
      break-inside: avoid;
    }

    .section-card h2 {
      margin: 0 0 14px;
      color: #102542;
      border-bottom: 2px solid rgba(23, 54, 95, 0.14);
      padding-bottom: 10px;
    }

    .section-card h3 {
      margin: 18px 0 10px;
      color: #17365f;
    }

    .summary-text,
    .section-card p,
    .legal-box {
      line-height: 1.7;
    }

    .intel-grid,
    .grid-2,
    .grid-3,
    .shot-grid {
      display: grid;
      gap: 16px;
    }

    .intel-grid {
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }

    .grid-2 {
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    }

    .grid-3 {
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    }

    .intel-card,
    .legal-box,
    .detail-panel,
    .tech-block {
      border-radius: 16px;
      padding: 16px;
      border: 1px solid rgba(15, 23, 42, 0.08);
      background: #f8fafc;
    }

    .intel-card.alert { background: #fff1f1; border-color: rgba(178, 34, 34, 0.3); }
    .intel-card.warn { background: #fff7ec; border-color: rgba(204, 85, 0, 0.28); }
    .intel-card.safe { background: #edf8f1; border-color: rgba(26, 107, 58, 0.28); }

    .intel-card .label {
      display: block;
      font-size: 0.76rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #5c6270;
      margin-bottom: 8px;
    }

    .intel-card strong {
      display: block;
      font-size: 1.28rem;
      margin-bottom: 6px;
    }

    .report-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.95rem;
    }

    .report-table th,
    .report-table td {
      text-align: left;
      padding: 10px 12px;
      border-bottom: 1px solid #e5e7eb;
      vertical-align: top;
      word-break: break-word;
    }

    .report-table th {
      color: #1f2937;
      background: #f5f7fb;
    }

    .new-domain-flag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      border-radius: 999px;
      background: rgba(178, 34, 34, 0.12);
      color: #8a1111;
      font-weight: 700;
      margin-top: 12px;
    }

    .cloaking-banner {
      padding: 12px 14px;
      border-radius: 14px;
      background: #fff2d9;
      border: 1px solid rgba(184, 134, 11, 0.35);
      color: #7c4a00;
      font-weight: 700;
      margin-bottom: 14px;
    }

    .shot-grid {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    }

    .shot-card {
      border-radius: 16px;
      border: 1px solid rgba(15, 23, 42, 0.08);
      overflow: hidden;
      background: #f8fafc;
    }

    .shot-head {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      padding: 12px 14px;
      background: #e8eff8;
      font-weight: 700;
    }

    .shot-media {
      background: #0f172a;
      aspect-ratio: 16 / 10;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .shot-media img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      cursor: zoom-in;
    }

    .shot-meta {
      padding: 12px 14px;
      font-size: 0.86rem;
      color: #334155;
    }

    .code-list {
      margin: 0;
      padding-left: 20px;
      word-break: break-word;
    }

    .action-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .agency-mark {
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-size: 0.78rem;
      color: rgba(255, 255, 255, 0.82);
      margin-bottom: 8px;
    }

    .lightbox {
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, 0.86);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 24px;
      z-index: 50;
    }

    .lightbox.active { display: flex; }

    .lightbox img {
      max-width: min(1200px, 95vw);
      max-height: 92vh;
      border-radius: 14px;
      box-shadow: 0 18px 45px rgba(0, 0, 0, 0.4);
    }

    .lightbox button {
      position: absolute;
      top: 24px;
      right: 24px;
      background: rgba(255, 255, 255, 0.18);
      color: #fff;
      border: 0;
      border-radius: 999px;
      width: 42px;
      height: 42px;
      font-size: 1.2rem;
      cursor: pointer;
    }

    @media (max-width: 960px) {
      .cover-grid,
      .cover-strip {
        grid-template-columns: 1fr;
      }
    }

    @media print {
      body.report-page {
        background: #fff;
      }
      .report-shell {
        padding: 0;
        max-width: none;
      }
      .cover-page,
      .report-hero,
      .section-card,
      .summary-matrix {
        box-shadow: none;
      }
      .hero-toolbar,
      .lightbox {
        display: none !important;
      }
      .shot-media img {
        cursor: default;
      }
      a {
        color: #10233c;
        text-decoration: none;
      }
    }
  </style>
</head>
<body class="report-page">
  <div class="report-shell">
    {% if is_pdf %}
      <section class="cover-page">
        <p class="cover-kicker">National Cybercrime Threat Analytics Unit</p>
        <h1>Cybercrime Domain Analysis Dossier</h1>
        <p class="cover-lead">
          Analyst-generated intelligence brief prepared in the style of an inter-agency cybercrime assessment pack.
          This document compiles passive-intelligence indicators, capture evidence, legal analysis, and infrastructure
          attribution for the subject domain listed below.
        </p>
        <div class="cover-grid">
          <div class="cover-panel">
            <dl>
              <div>
                <dt>Subject Domain</dt>
                <dd>{{ report.domain }}</dd>
              </div>
              <div>
                <dt>Input URL</dt>
                <dd>{{ report.input_url }}</dd>
              </div>
              <div>
                <dt>Report Identifier</dt>
                <dd>{{ report_identifier }}</dd>
              </div>
              <div>
                <dt>Draft Handling Note</dt>
                <dd>{{ report_disclaimer }}</dd>
              </div>
            </dl>
            <div class="cover-badges">
              <span class="badge severity {{ report.ai_analysis.severity|lower }}">{{ report.ai_analysis.severity }}</span>
              <span class="badge category">{{ report.ai_analysis.threat_category }}</span>
              <span class="badge neutral">{{ report.batch_id }}</span>
            </div>
          </div>
          <aside class="cover-panel">
            <dl>
              <div>
                <dt>Analysis Timestamp (UTC)</dt>
                <dd>{{ report.analysis_ts_utc }}</dd>
              </div>
              <div>
                <dt>Priority Score</dt>
                <dd>{{ report.ai_analysis.priority_score }}</dd>
              </div>
              <div>
                <dt>Primary Allocation Holder</dt>
                <dd>{{ report.network_attribution.primary_holder or 'Unavailable' }}</dd>
              </div>
              <div>
                <dt>Primary Allocation Region</dt>
                <dd>{{ report.network_attribution.primary_economy_name or report.network_attribution.primary_cc or 'Unavailable' }}</dd>
              </div>
            </dl>
          </aside>
        </div>
      </section>
    {% endif %}
    <header class="report-hero">
      <div class="cover-strip">
        <div>
          <p class="agency-mark">National Cybercrime Threat Analytics Unit (NCTAU)</p>
          <p class="agency-mark">Indian Cyber Crime Coordination Centre (I4C) - Analyst Draft</p>
          <h1>Cybercrime Domain Analysis Report</h1>
          <p><strong>Subject domain:</strong> {{ report.domain }}</p>
          <p><strong>Input URL:</strong> {{ report.input_url }}</p>
          <div class="hero-meta">
            <span class="badge severity {{ report.ai_analysis.severity|lower }}">{{ report.ai_analysis.severity }}</span>
            <span class="badge category">{{ report.ai_analysis.threat_category }}</span>
            <span class="badge neutral">{{ report.batch_id }}</span>
          </div>
        </div>
        <aside class="cover-meta">
          <dl>
            <div>
              <dt>Report ID</dt>
              <dd>{{ report_identifier }}</dd>
            </div>
            <div>
              <dt>Analysis Timestamp (UTC)</dt>
              <dd>{{ report.analysis_ts_utc }}</dd>
            </div>
            <div>
              <dt>Priority Score</dt>
              <dd>{{ report.ai_analysis.priority_score }}</dd>
            </div>
            <div>
              <dt>Primary Allocation Holder</dt>
              <dd>{{ report.network_attribution.primary_holder or 'Unavailable' }}</dd>
            </div>
          </dl>
        </aside>
      </div>
      {% if not is_pdf %}
        <div class="hero-toolbar">
          <div class="disclaimer-banner">
            <strong>Draft handling note:</strong> {{ report_disclaimer }}
          </div>
          <div class="action-stack">
            <a class="button primary" href="{{ pdf_report_link }}">Download PDF Report</a>
            <a class="button secondary" href="{{ evidence_zip_link }}">Download Evidence ZIP</a>
            <a class="button secondary" href="{{ raw_json_link }}">View Raw JSON</a>
          </div>
        </div>
      {% endif %}
    </header>

    <section class="summary-matrix">
      <article>
        <span class="label">Severity</span>
        <strong>{{ report.ai_analysis.severity }}</strong>
      </article>
      <article>
        <span class="label">Threat Category</span>
        <strong>{{ report.ai_analysis.threat_category }}</strong>
      </article>
      <article>
        <span class="label">Confidence</span>
        <strong>{{ report.ai_analysis.confidence }}</strong>
      </article>
      <article>
        <span class="label">Brand Impersonated</span>
        <strong>{{ report.ai_analysis.brand_impersonated or 'None identified' }}</strong>
      </article>
      <article>
        <span class="label">Resolved IPs</span>
        <strong>{{ report.network_attribution.resolved_ips|length }}</strong>
      </article>
      <article>
        <span class="label">Holder-linked ASNs</span>
        <strong>{{ report.network_attribution.holder_linked_asns|length }}</strong>
      </article>
    </section>

    <section class="section-card" id="section-a">
      <h2>A - Executive Summary</h2>
      <p class="summary-text">{{ report.ai_analysis.illegal_activity_description }}</p>
      <div class="grid-2">
        <div class="legal-box">
          <strong>Fraud mechanism</strong>
          <p>{{ report.ai_analysis.fraud_mechanism or 'N/A' }}</p>
          <strong>Victim profile</strong>
          <p>{{ report.ai_analysis.victim_profile or 'N/A' }}</p>
        </div>
        <div class="legal-box">
          <strong>Attribution summary</strong>
          <p>
            {% if report.network_attribution.primary_holder %}
              The primary resolved infrastructure maps to APNIC allocation holder
              <strong>{{ report.network_attribution.primary_holder }}</strong>
              {% if report.network_attribution.primary_economy_name %}
                in {{ report.network_attribution.primary_economy_name }}
              {% endif %}.
            {% else %}
              No APNIC allocation holder was identified for the resolved addresses captured during this run.
            {% endif %}
          </p>
          <p><strong>Recommended action:</strong> {{ report.ai_analysis.recommended_action or 'N/A' }}</p>
        </div>
      </div>
    </section>

    <section class="section-card" id="section-b">
      <h2>B - Threat Intel Verdicts</h2>
      <div class="intel-grid">
        <div class="intel-card {% if report.threat_intel.vt_malicious > 0 %}alert{% elif report.threat_intel.vt_suspicious > 0 %}warn{% else %}safe{% endif %}">
          <span class="label">VirusTotal</span>
          <strong>{{ report.threat_intel.vt_malicious }}/{{ report.threat_intel.vt_total }}</strong>
          <span>Malicious engines flagged</span>
        </div>
        <div class="intel-card {% if report.threat_intel.urlscan_verdict == 'malicious' %}alert{% elif report.threat_intel.urlscan_verdict %}warn{% else %}safe{% endif %}">
          <span class="label">URLScan</span>
          <strong>{{ report.threat_intel.urlscan_verdict or 'N/A' }}</strong>
          <span>Score: {{ report.threat_intel.urlscan_score if report.threat_intel.urlscan_score is not none else 'N/A' }}</span>
        </div>
        <div class="intel-card {% if report.threat_intel.urlhaus_listed %}alert{% else %}safe{% endif %}">
          <span class="label">URLhaus</span>
          <strong>{{ 'Listed' if report.threat_intel.urlhaus_listed else 'Not listed' }}</strong>
          <span>{{ report.threat_intel.urlhaus_threat or 'No malware tag returned' }}</span>
        </div>
        <div class="intel-card {% if report.threat_intel.gsb_threats %}alert{% else %}safe{% endif %}">
          <span class="label">Google Safe Browsing</span>
          <strong>{{ report.threat_intel.gsb_threats|join(', ') if report.threat_intel.gsb_threats else 'Clean' }}</strong>
          <span>Blocklist presence</span>
        </div>
        <div class="intel-card {% if report.threat_intel.otx_pulse_count > 0 %}warn{% else %}safe{% endif %}">
          <span class="label">AlienVault OTX</span>
          <strong>{{ report.threat_intel.otx_pulse_count }}</strong>
          <span>Threat pulses</span>
        </div>
        <div class="intel-card {% if report.threat_intel.phishtank_verified %}alert{% else %}safe{% endif %}">
          <span class="label">PhishTank</span>
          <strong>{{ 'Verified' if report.threat_intel.phishtank_verified else 'Unverified' }}</strong>
          <span>Community phishing consensus</span>
        </div>
        <div class="intel-card {% if report.threat_intel.abuseipdb_score and report.threat_intel.abuseipdb_score >= 50 %}warn{% else %}safe{% endif %}">
          <span class="label">AbuseIPDB</span>
          <strong>{{ report.threat_intel.abuseipdb_score if report.threat_intel.abuseipdb_score is not none else 'N/A' }}</strong>
          <span>{{ report.threat_intel.abuseipdb_isp or 'ISP unavailable' }}</span>
        </div>
      </div>
    </section>

    <section class="section-card" id="section-c">
      <h2>C - Registration and DNS</h2>
      <div class="grid-2">
        <div class="detail-panel">
          <table class="report-table">
            <tbody>
              <tr><th>Registrar</th><td>{{ report.registration.registrar or 'Unknown' }}</td></tr>
              <tr><th>Registration date</th><td>{{ report.registration.registered or 'Unknown' }}</td></tr>
              <tr><th>Expiry date</th><td>{{ report.registration.expires or 'Unknown' }}</td></tr>
              <tr><th>Nameservers</th><td>{{ report.registration.nameservers|join(', ') if report.registration.nameservers else 'Unknown' }}</td></tr>
              <tr><th>Registrant country</th><td>{{ report.registration.country or 'Unknown' }}</td></tr>
              <tr><th>Domain age</th><td>{{ domain_age.days ~ ' days' if domain_age.days is not none else 'Unknown' }}</td></tr>
            </tbody>
          </table>
          {% if domain_age.is_new_domain %}
            <div class="new-domain-flag">NEW DOMAIN - Registered within 30 days</div>
          {% endif %}
        </div>
        <div class="detail-panel">
          <h3>DNS Records</h3>
          <table class="report-table">
            <tbody>
              {% for record_type, values in report.dns_records.items() %}
                <tr>
                  <th>{{ record_type }}</th>
                  <td>{{ values|join(', ') if values else 'No record returned' }}</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="section-card" id="section-d">
      <h2>D - Evidence Capture</h2>
      {% if capture_cards | selectattr('cloaking_suspected') | list %}
        <div class="cloaking-banner">CLOAKING SUSPECTED - Desktop and mobile captures differ materially.</div>
      {% endif %}
      <div class="shot-grid">
        {% for card in capture_cards %}
          <article class="shot-card">
            <div class="shot-head">
              <span>{{ card.profile|replace('_', ' ')|title }}</span>
              <span>{{ card.http_status if card.http_status is not none else 'Capture failed' }}</span>
            </div>
            {% if card.error %}
              <div class="shot-meta">{{ card.error }}</div>
            {% endif %}
            {% if card.viewport_data_uri %}
              <div class="shot-media">
                <img src="{{ card.viewport_data_uri }}" alt="{{ card.profile }} viewport screenshot" data-lightbox="{{ card.viewport_data_uri }}">
              </div>
              <div class="shot-meta">
                <strong>Viewport screenshot</strong><br>
                Timestamp: {{ card.timestamp or 'N/A' }}<br>
                SHA-256: {{ card.viewport_hash or 'N/A' }}
              </div>
            {% endif %}
            {% if card.full_data_uri %}
              <div class="shot-media">
                <img src="{{ card.full_data_uri }}" alt="{{ card.profile }} full-page screenshot" data-lightbox="{{ card.full_data_uri }}">
              </div>
              <div class="shot-meta">
                <strong>Full-page screenshot</strong><br>
                Timestamp: {{ card.timestamp or 'N/A' }}<br>
                SHA-256: {{ card.full_hash or 'N/A' }}
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    </section>

    <section class="section-card" id="section-e">
      <h2>E - Legal Analysis</h2>
      <table class="report-table">
        <thead>
          <tr>
            <th>Statute</th>
            <th>Offence</th>
            <th>Evidence</th>
            <th>Confidence</th>
          </tr>
        </thead>
        <tbody>
          {% if report.ai_analysis.applicable_laws %}
            {% for law in report.ai_analysis.applicable_laws %}
              <tr>
                <td>{{ law.statute or law['statute'] }}</td>
                <td>{{ law.offence or law['offence'] }}</td>
                <td>{{ law.evidence or law['evidence'] }}</td>
                <td>{{ law.confidence or law['confidence'] }}</td>
              </tr>
            {% endfor %}
          {% else %}
            <tr><td colspan="4">No specific legal provisions were assigned by the analytical model for this capture.</td></tr>
          {% endif %}
        </tbody>
      </table>
      <div class="legal-box" style="margin-top: 16px;">
        {{ report.ai_analysis.illegal_activity_description }}
      </div>
    </section>

    <section class="section-card" id="section-f">
      <h2>F - Network Attribution</h2>
      <div class="grid-2">
        <div class="detail-panel">
          <h3>Resolved IP Set</h3>
          <ul class="code-list">
            {% for ip in report.network_attribution.resolved_ips %}
              <li>{{ ip }}</li>
            {% else %}
              <li>No IPv4 or IPv6 addresses were resolved during this run.</li>
            {% endfor %}
          </ul>
          <h3>Holder-linked ASN Allocations</h3>
          <ul class="code-list">
            {% for asn in report.network_attribution.holder_linked_asns %}
              <li>
                <strong>{{ asn.resource }}</strong>
                {% if asn.holder_name %}<br>{{ asn.holder_name }}{% endif %}
                {% if asn.economy_name or asn.cc %}<br>{{ asn.economy_name or 'Unknown economy' }}{% if asn.cc %} ({{ asn.cc }}){% endif %}{% endif %}
              </li>
            {% else %}
              <li>No holder-linked ASN allocations were identified from the APNIC dataset.</li>
            {% endfor %}
          </ul>
        </div>
        <div class="detail-panel">
          <h3>Primary Allocation Holder</h3>
          <p><strong>{{ report.network_attribution.primary_holder or 'Unavailable' }}</strong></p>
          <p>
            {% if report.network_attribution.primary_economy_name or report.network_attribution.primary_cc %}
              {{ report.network_attribution.primary_economy_name or 'Unknown economy' }}
              {% if report.network_attribution.primary_cc %}({{ report.network_attribution.primary_cc }}){% endif %}
            {% else %}
              No APNIC geography was matched.
            {% endif %}
          </p>
        </div>
      </div>
      <h3>Matched APNIC Allocations</h3>
      <table class="report-table">
        <thead>
          <tr>
            <th>IP</th>
            <th>Resource</th>
            <th>Holder</th>
            <th>NIR / Country</th>
            <th>Economy</th>
            <th>Delegation</th>
          </tr>
        </thead>
        <tbody>
          {% for allocation in report.network_attribution.matched_allocations %}
            <tr>
              <td>{{ allocation.ip_address }}</td>
              <td>{{ allocation.resource }}</td>
              <td>{{ allocation.holder_name or 'Unknown' }}</td>
              <td>{{ allocation.nir or 'N/A' }}{% if allocation.cc %} / {{ allocation.cc }}{% endif %}</td>
              <td>{{ allocation.economy_name or 'Unknown' }}</td>
              <td>{{ allocation.delegation_date or 'Unknown' }}</td>
            </tr>
          {% else %}
            <tr><td colspan="6">No APNIC allocation block matched the resolved IP set.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </section>

    <section class="section-card" id="section-g">
      <h2>G - Technical Observations and Link Analysis</h2>
      <div class="grid-2">
        <div class="tech-block">
          <table class="report-table">
            <tbody>
              <tr><th>HTTP status</th><td>{{ primary_capture.http_status if primary_capture else 'N/A' }}</td></tr>
              <tr><th>Final URL</th><td>{{ primary_capture.final_url if primary_capture else 'N/A' }}</td></tr>
              <tr><th>Page title</th><td>{{ primary_capture.title if primary_capture else 'N/A' }}</td></tr>
              <tr><th>Redirect chain</th><td>{{ redirect_chain|join(' → ') if redirect_chain else 'No redirects recorded' }}</td></tr>
              <tr><th>Wayback snapshot</th><td>{% if wayback_snapshot.url %}<a href="{{ wayback_snapshot.url }}">Archived copy</a>{% else %}Not available{% endif %}</td></tr>
            </tbody>
          </table>
          <h3>Network Requests</h3>
          <ul class="code-list">
            <li><strong>First-party:</strong> {{ network_requests.first_party|length if network_requests.first_party is defined else 0 }}</li>
            <li><strong>Third-party:</strong> {{ network_requests.third_party|length if network_requests.third_party is defined else 0 }}</li>
            <li><strong>API calls:</strong> {{ network_requests.api_calls|length if network_requests.api_calls is defined else 0 }}</li>
          </ul>
        </div>
        <div class="tech-block">
          <h3>Certificate Transparency (first 10)</h3>
          <ul class="code-list">
            {% for cert in first_ten_certs %}
              <li><strong>{{ cert.name }}</strong><br>{{ cert.issuer }}<br>{{ cert.not_before }}</li>
            {% else %}
              <li>No certificate transparency records returned.</li>
            {% endfor %}
          </ul>
          <h3>Linked Domains (shared infrastructure)</h3>
          <ul class="code-list">
            {% for linked in linked_domains %}
              <li>{{ linked }}</li>
            {% else %}
              <li>No linked domains were identified in the current dataset.</li>
            {% endfor %}
          </ul>
          <h3>Response Headers</h3>
          <ul class="code-list">
            {% for key, value in response_headers.items() %}
              <li><strong>{{ key }}:</strong> {{ value }}</li>
            {% else %}
              <li>No response headers recorded.</li>
            {% endfor %}
          </ul>
        </div>
      </div>
    </section>

    <section class="section-card" id="section-h">
      <h2>H - Evidence Manifest and Recommendations</h2>
      <div class="grid-2">
        <div class="legal-box">
          <p><strong>Recommended action:</strong> {{ report.ai_analysis.recommended_action or 'N/A' }}</p>
          <p><strong>Severity:</strong> {{ report.ai_analysis.severity }}</p>
          <p><strong>Priority score:</strong> {{ report.ai_analysis.priority_score }}</p>
          {% if not is_pdf %}
            <div class="action-stack">
              <a class="button primary" href="{{ pdf_report_link }}">Download PDF Report</a>
              <a class="button secondary" href="{{ evidence_zip_link }}">Download Evidence ZIP</a>
              <a class="button secondary" href="{{ raw_json_link }}">View Raw JSON</a>
            </div>
          {% endif %}
        </div>
        <div class="legal-box">
          <p><strong>Manifest hash:</strong> {{ report.evidence_manifest_hash or 'N/A' }}</p>
          <p>{{ report_disclaimer }}</p>
        </div>
      </div>
      <table class="report-table" style="margin-top: 16px;">
        <thead>
          <tr>
            <th>File</th>
            <th>Type</th>
            <th>Profile</th>
            <th>Timestamp</th>
            <th>SHA-256</th>
          </tr>
        </thead>
        <tbody>
          {% for item in manifest_entries %}
            <tr>
              <td>{{ item.file }}</td>
              <td>{{ item.type }}</td>
              <td>{{ item.profile }}</td>
              <td>{{ item.timestamp }}</td>
              <td>{{ item.hash }}</td>
            </tr>
          {% else %}
            <tr><td colspan="5">No manifest entries were generated.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </section>
  </div>

  {% if not is_pdf %}
    <div class="lightbox" id="lightbox">
      <button type="button" aria-label="Close lightbox" onclick="window.closeReportLightbox()">×</button>
      <img alt="Expanded screenshot preview" id="lightbox-image">
    </div>

    <script>
      window.closeReportLightbox = function () {
        document.getElementById('lightbox').classList.remove('active');
      };
      document.querySelectorAll('[data-lightbox]').forEach(function (image) {
        image.addEventListener('click', function () {
          document.getElementById('lightbox-image').src = image.getAttribute('data-lightbox');
          document.getElementById('lightbox').classList.add('active');
        });
      });
      document.getElementById('lightbox').addEventListener('click', function (event) {
        if (event.target.id === 'lightbox') {
          window.closeReportLightbox();
        }
      });
    </script>
  {% endif %}
</body>
</html>
