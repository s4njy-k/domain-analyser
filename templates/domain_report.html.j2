<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ report.domain }} - I4C Domain and IP Threat Intelligence Report</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;500;600;700;800&family=Source+Serif+4:opsz,wght@8..60,600;8..60,700&display=swap" rel="stylesheet">
  <style>
    @page {
      size: A4;
      margin: 17mm 13mm 18mm;
      @top-left {
        content: "I4C / NCTAU Analytical Draft";
        color: #4f667f;
        font-size: 9pt;
      }
      @top-right {
        content: "{{ report_identifier }}";
        color: #4f667f;
        font-size: 9pt;
      }
      @bottom-left {
        content: "{{ report_disclaimer }}";
        color: #71859a;
        font-size: 8pt;
      }
      @bottom-right {
        content: "Page " counter(page) " of " counter(pages);
        color: #4f667f;
        font-size: 9pt;
      }
    }

    :root {
      --paper: #f3f5f7;
      --surface: #ffffff;
      --surface-soft: #f7f9fb;
      --surface-strong: #ebeff3;
      --border: rgba(18, 41, 68, 0.12);
      --border-strong: rgba(18, 41, 68, 0.22);
      --text-strong: #10243d;
      --text-main: #28425f;
      --text-muted: #62788f;
      --blue: #0f4ea8;
      --teal: #14859a;
      --saffron: #d39f11;
      --green: #1d8654;
      --red: #bf4352;
      --critical: #bf4352;
      --high: #d77a27;
      --medium: #c89a12;
      --low: #1d8654;
      --inactive: #6f8092;
      --shadow: 0 18px 40px rgba(16, 39, 68, 0.07);
      --radius-xl: 20px;
      --radius-lg: 14px;
      --radius-md: 10px;
      --radius-sm: 8px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: "Source Sans 3", "Aptos", "Segoe UI", sans-serif;
      background: linear-gradient(180deg, #f2f4f6, #f8fafb 24%, #f2f5f7 100%);
      color: var(--text-main);
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .report-shell {
      max-width: 1240px;
      margin: 0 auto;
      padding: 22px;
    }

    .cover-sheet,
    .report-header,
    .section-card,
    .summary-grid {
      border-radius: var(--radius-lg);
      background: var(--surface);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
    }

    .cover-sheet {
      position: relative;
      overflow: hidden;
      min-height: calc(100vh - 44px);
      margin-bottom: 22px;
      padding: 36px 34px 30px;
      background:
        linear-gradient(180deg, rgba(15, 78, 168, 0.05), rgba(15, 78, 168, 0) 110px),
        linear-gradient(180deg, #ffffff 0%, #fafbfd 100%);
      color: var(--text-main);
      page-break-after: always;
    }

    .cover-sheet::before {
      content: "";
      position: absolute;
      inset: 0 0 auto;
      height: 8px;
      background: linear-gradient(90deg, var(--blue) 0%, var(--blue) 38%, var(--green) 72%, var(--saffron) 100%);
    }

    .cover-top,
    .report-brand {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 20px;
    }

    .cover-lockup,
    .brand-lockup {
      display: flex;
      align-items: flex-start;
      gap: 18px;
    }

    .report-logo {
      width: 162px;
      height: auto;
      flex: 0 0 auto;
    }

    .cover-kicker,
    .section-kicker {
      margin: 0 0 8px;
      font-size: 0.74rem;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--blue);
      font-weight: 700;
    }

    .cover-title,
    .report-title {
      font-family: "Source Serif 4", Georgia, serif;
      line-height: 1.02;
      color: inherit;
      margin: 0;
    }

    .cover-title {
      font-size: clamp(2.3rem, 4vw, 3.7rem);
      max-width: 11ch;
      color: var(--text-strong);
    }

    .cover-intro {
      max-width: 60rem;
      margin: 18px 0 0;
      color: var(--text-main);
      line-height: 1.74;
      font-size: 1rem;
    }

    .classification-pill,
    .meta-chip,
    .badge,
    .severity-pill,
    .status-pill {
      display: inline-flex;
      align-items: center;
      padding: 7px 12px;
      border-radius: 999px;
      font-weight: 800;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      font-size: 0.74rem;
    }

    .classification-pill,
    .meta-chip,
    .badge.category,
    .badge.neutral {
      background: var(--surface-soft);
      color: var(--text-strong);
      border: 1px solid var(--border);
    }

    .meta-chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 18px;
    }

    .cover-side {
      width: min(360px, 100%);
      padding: 18px 20px;
      border-radius: var(--radius-lg);
      background: var(--surface-soft);
      border: 1px solid var(--border);
    }

    .cover-side dl,
    .summary-grid dl,
    .summary-stack dl {
      margin: 0;
      display: grid;
      gap: 12px;
    }

    .cover-side dt,
    .summary-grid dt,
    .summary-stack dt {
      margin-bottom: 4px;
      font-size: 0.73rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-muted);
    }

    .cover-side dd,
    .summary-grid dd,
    .summary-stack dd {
      margin: 0;
      font-size: 0.96rem;
      font-weight: 700;
      word-break: break-word;
      color: var(--text-strong);
    }

    .cover-note {
      margin-top: 20px;
      padding: 16px 18px;
      border-radius: var(--radius-lg);
      background: #f9fbfd;
      border: 1px solid var(--border);
      line-height: 1.72;
      color: var(--text-main);
    }

    .report-header {
      overflow: hidden;
      margin-bottom: 18px;
    }

    .report-brand {
      padding: 24px 26px 22px;
      background:
        linear-gradient(90deg, rgba(15, 78, 168, 0.04), rgba(15, 78, 168, 0) 24%),
        #ffffff;
      color: var(--text-main);
      border-bottom: 1px solid var(--border);
    }

    .report-title {
      font-size: clamp(2rem, 3vw, 2.65rem);
      margin-bottom: 10px;
      color: var(--text-strong);
    }

    .report-subcopy {
      margin: 0;
      max-width: 58rem;
      line-height: 1.72;
      color: var(--text-main);
    }

    .report-meta {
      min-width: 280px;
      padding: 18px;
      border-radius: var(--radius-lg);
      background: var(--surface-soft);
      border: 1px solid var(--border);
    }

    .report-meta dl {
      margin: 0;
      display: grid;
      gap: 10px;
    }

    .report-meta dt {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--text-muted);
      margin-bottom: 4px;
    }

    .report-meta dd {
      margin: 0;
      font-weight: 700;
      word-break: break-word;
      color: var(--text-strong);
    }

    .toolbar {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 14px;
      padding: 16px 24px 20px;
      background: #fbfcfd;
      border-top: 1px solid var(--border);
    }

    .toolbar-note {
      flex: 1 1 420px;
      padding: 12px 14px;
      border-radius: var(--radius-md);
      background: #fffaf0;
      color: #7d5a00;
      border: 1px solid rgba(211, 159, 17, 0.28);
      line-height: 1.65;
    }

    .action-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: flex-start;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      min-height: 44px;
      padding: 11px 17px;
      border-radius: 999px;
      border: 1px solid transparent;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 800;
      transition: transform 0.18s ease, opacity 0.18s ease, box-shadow 0.18s ease;
    }

    .button:hover {
      transform: translateY(-1px);
    }

    .button.primary {
      background: linear-gradient(135deg, #0f4ea8, #2678d7);
      color: #f9fcff;
      box-shadow: 0 10px 22px rgba(15, 78, 168, 0.16);
    }

    .button.secondary {
      background: #f5f8fc;
      border-color: var(--border);
      color: var(--text-strong);
    }

    .button.disabled,
    .button[aria-disabled="true"] {
      opacity: 0.58;
      pointer-events: none;
      cursor: not-allowed;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 1px;
      overflow: hidden;
      margin-bottom: 18px;
      background: var(--border);
    }

    .summary-grid > div {
      background: var(--surface);
      padding: 20px 22px;
    }

    .summary-topline {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      margin-bottom: 16px;
    }

    .summary-card {
      padding: 14px 16px;
      border-radius: var(--radius-md);
      background: var(--surface-soft);
      border: 1px solid var(--border);
    }

    .summary-card .label {
      display: block;
      margin-bottom: 8px;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-muted);
    }

    .summary-card strong {
      display: block;
      color: var(--text-strong);
      font-size: 1.28rem;
      line-height: 1.1;
    }

    .summary-stack {
      display: grid;
      gap: 14px;
    }

    .note-box,
    .detail-panel,
    .evidence-card,
    .legal-panel,
    .tech-panel {
      border-radius: var(--radius-lg);
      border: 1px solid var(--border);
      background: var(--surface-soft);
    }

    .note-box,
    .detail-panel,
    .legal-panel,
    .tech-panel {
      padding: 16px 18px;
    }

    .note-box {
      line-height: 1.72;
      color: var(--text-main);
    }

    .note-box strong {
      color: var(--text-strong);
    }

    .grid-2,
    .grid-3,
    .capture-grid {
      display: grid;
      gap: 16px;
    }

    .grid-2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .grid-3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .section-card {
      padding: 22px;
      margin-bottom: 18px;
    }

    .section-card h2 {
      margin: 0 0 14px;
      font-family: "Source Serif 4", Georgia, serif;
      font-size: 1.55rem;
      line-height: 1.08;
      color: var(--text-strong);
    }

    .section-intro {
      margin: 0 0 18px;
      color: var(--text-muted);
      line-height: 1.7;
    }

    .report-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.92rem;
    }

    .report-table th,
    .report-table td {
      text-align: left;
      padding: 11px 10px;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
      word-break: break-word;
    }

    .report-table th {
      color: var(--text-strong);
      background: #eff4f8;
      font-size: 0.76rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    .severity-pill.critical,
    .badge.severity.critical {
      background: rgba(217, 79, 94, 0.16);
      color: #d94f5e;
    }

    .severity-pill.high,
    .badge.severity.high {
      background: rgba(241, 138, 46, 0.16);
      color: #d36d07;
    }

    .severity-pill.medium,
    .badge.severity.medium {
      background: rgba(239, 193, 72, 0.16);
      color: #b07d05;
    }

    .severity-pill.low,
    .badge.severity.low {
      background: rgba(51, 165, 112, 0.16);
      color: #12754c;
    }

    .severity-pill.inactive,
    .badge.severity.inactive,
    .badge.severity.unknown {
      background: rgba(124, 136, 151, 0.16);
      color: #516373;
    }

    .badge.category,
    .badge.neutral {
      background: rgba(15, 78, 168, 0.06);
      color: var(--text-strong);
      border: 1px solid var(--border);
    }

    .status-pill {
      background: rgba(16, 135, 83, 0.14);
      color: #12754c;
    }

    .status-pill.down,
    .status-pill.inactive {
      background: rgba(124, 136, 151, 0.16);
      color: #536675;
    }

    .capture-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .evidence-card {
      overflow: hidden;
    }

    .evidence-head {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      align-items: center;
      padding: 14px 16px;
      background: linear-gradient(180deg, #eef3f8, #f8fafc);
      color: var(--text-strong);
      font-weight: 800;
      border-bottom: 1px solid var(--border);
    }

    .evidence-frame {
      aspect-ratio: 16 / 10;
      background: #0b1621;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .evidence-frame img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      cursor: zoom-in;
    }

    .evidence-meta {
      padding: 14px 16px;
      font-size: 0.84rem;
      color: var(--text-main);
      line-height: 1.7;
    }

    .key-list {
      margin: 0;
      padding-left: 18px;
      color: var(--text-main);
      line-height: 1.7;
    }

    .key-list li + li {
      margin-top: 6px;
    }

    .muted {
      color: var(--text-muted);
    }

    .lightbox {
      position: fixed;
      inset: 0;
      background: rgba(10, 20, 34, 0.88);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 24px;
      z-index: 50;
    }

    .lightbox.active {
      display: flex;
    }

    .lightbox img {
      max-width: min(1220px, 95vw);
      max-height: 92vh;
      border-radius: 16px;
      box-shadow: 0 20px 48px rgba(0, 0, 0, 0.35);
    }

    .lightbox button {
      position: absolute;
      top: 24px;
      right: 24px;
      width: 42px;
      height: 42px;
      border-radius: 999px;
      border: 0;
      background: rgba(255, 255, 255, 0.18);
      color: #fff;
      font-size: 1.2rem;
      cursor: pointer;
    }

    @media (max-width: 1080px) {
      .summary-grid,
      .grid-2,
      .grid-3,
      .capture-grid,
      .report-brand,
      .cover-top {
        grid-template-columns: 1fr;
      }

      .report-brand,
      .cover-top {
        flex-direction: column;
      }

      .summary-topline {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 680px) {
      .report-shell {
        padding: 12px;
      }

      .summary-topline {
        grid-template-columns: 1fr;
      }

      .capture-grid {
        grid-template-columns: 1fr;
      }

      .button {
        width: 100%;
      }
    }

    @media print {
      body {
        background: #fff;
      }

      .report-shell {
        max-width: none;
        padding: 0;
      }

      .cover-sheet,
      .report-header,
      .section-card,
      .summary-grid {
        box-shadow: none;
      }

      .toolbar,
      .lightbox {
        display: none !important;
      }

      a {
        color: inherit;
      }
    }
  </style>
</head>
<body>
  <div class="report-shell">
    {% if is_pdf %}
      <section class="cover-sheet">
        <div class="cover-top">
          <div class="cover-lockup">
            {% if logo_data_uri %}
              <img class="report-logo" src="{{ logo_data_uri }}" alt="I4C logo">
            {% endif %}
            <div>
              <p class="cover-kicker">Indian Cyber Crime Coordination Centre</p>
              <div class="classification-pill">Analytical Draft • Circulation Copy</div>
              <h1 class="cover-title">Domain and IP threat intelligence report</h1>
            </div>
          </div>
          <aside class="cover-side">
            <dl>
              <div>
                <dt>Report Identifier</dt>
                <dd>{{ report_identifier }}</dd>
              </div>
              <div>
                <dt>Subject Domain</dt>
                <dd>{{ report.domain }}</dd>
              </div>
              <div>
                <dt>Analysis Timestamp (UTC)</dt>
                <dd>{{ report.analysis_ts_utc }}</dd>
              </div>
              <div>
                <dt>Severity</dt>
                <dd>{{ report.ai_analysis.severity }}</dd>
              </div>
            </dl>
          </aside>
        </div>
        <p class="cover-intro">
          This analytical draft consolidates observed website behaviour, supporting technical evidence, infrastructure signals,
          payment indicators, and preliminary statutory relevance for the subject domain and its associated hosting footprint.
          It is intended to support structured review by government entities, intermediaries, and affected private-sector
          organisations that require a concise and technically reliable decision brief.
        </p>
        <div class="meta-chip-row">
          <span class="meta-chip">Batch {{ report.batch_id }}</span>
          <span class="meta-chip">Threat category {{ report.ai_analysis.threat_category }}</span>
          <span class="meta-chip">Priority score {{ report.ai_analysis.priority_score }}</span>
          <span class="meta-chip">Primary holder {{ report.network_attribution.primary_holder or 'Unavailable' }}</span>
        </div>
        <div class="cover-note">
          <strong>Handling note:</strong> {{ report_disclaimer }}<br>
          <strong>Interpretation note:</strong> Network attribution and holder-linked ASN references support investigative
          context but do not by themselves establish control, ownership, or criminal liability. Legal conclusions remain
          subject to review by the receiving authority.
        </div>
      </section>
    {% endif %}

    <header class="report-header">
      <div class="report-brand">
        <div class="brand-lockup">
            {% if logo_data_uri %}
              <img class="report-logo" src="{{ logo_data_uri }}" alt="I4C logo">
            {% endif %}
          <div>
            <p class="cover-kicker">National Cybercrime Threat Analytics Unit</p>
            <h1 class="report-title">Domain and IP threat intelligence report</h1>
            <p class="report-subcopy">
              Subject domain <strong>{{ report.domain }}</strong> assessed through passive intelligence, controlled browser
              capture, APNIC-based infrastructure enrichment, and preliminary statutory mapping aligned to Indian cybercrime response.
            </p>
            <div class="meta-chip-row">
              <span class="badge severity {{ report.ai_analysis.severity|lower }}">{{ report.ai_analysis.severity }}</span>
              <span class="badge category">{{ report.ai_analysis.threat_category }}</span>
              <span class="badge neutral">{{ report.batch_id }}</span>
            </div>
          </div>
        </div>
        <aside class="report-meta">
          <dl>
            <div>
              <dt>Report ID</dt>
              <dd>{{ report_identifier }}</dd>
            </div>
            <div>
              <dt>Input URL</dt>
              <dd>{{ report.input_url }}</dd>
            </div>
            <div>
              <dt>Primary Allocation Holder</dt>
              <dd>{{ report.network_attribution.primary_holder or 'Unavailable' }}</dd>
            </div>
            <div>
              <dt>Analysis Timestamp (UTC)</dt>
              <dd>{{ report.analysis_ts_utc }}</dd>
            </div>
          </dl>
        </aside>
      </div>
      {% if not is_pdf %}
        <div class="toolbar">
          <div class="toolbar-note">
            <strong>Draft handling note:</strong> {{ report_disclaimer }}
          </div>
          <div class="action-stack">
            <a class="button secondary" href="{{ dashboard_link }}">Open Dashboard</a>
            <a class="button secondary" href="{{ batch_csv_link }}" download>Download Full CSV</a>
            <a class="button secondary" href="{{ batch_evidence_link }}" download>Download Evidence Package</a>
            {% if pdf_available %}
              <a class="button primary" href="{{ pdf_report_link }}" download>Download PDF Report</a>
            {% else %}
              <span class="button secondary disabled" aria-disabled="true">PDF unavailable for this run</span>
            {% endif %}
            {% if evidence_available %}
              <a class="button secondary" href="{{ evidence_zip_link }}" download>Download Evidence ZIP</a>
            {% else %}
              <span class="button secondary disabled" aria-disabled="true">Evidence ZIP unavailable</span>
            {% endif %}
            <a class="button secondary" href="{{ raw_json_link }}">View Raw JSON</a>
          </div>
        </div>
      {% endif %}
    </header>

    <section class="summary-grid">
      <div>
        <div class="summary-topline">
          <article class="summary-card">
            <span class="label">Severity</span>
            <strong>{{ report.ai_analysis.severity }}</strong>
          </article>
          <article class="summary-card">
            <span class="label">Threat Category</span>
            <strong>{{ report.ai_analysis.threat_category }}</strong>
          </article>
          <article class="summary-card">
            <span class="label">Confidence</span>
            <strong>{{ report.ai_analysis.confidence }}</strong>
          </article>
          <article class="summary-card">
            <span class="label">Payment Indicators</span>
            <strong>{{ report.payment_methods|length }}</strong>
          </article>
        </div>
        <div class="note-box">
          <strong>Interpretation note.</strong>
          The executive assessment states the likely operational concern. Threat-intelligence verdicts indicate what external
          sources independently flagged. Infrastructure and attribution sections explain where the domain and associated IP
          footprint appear to be hosted and which resource-holder signals were observed. The legal section is an analyst aid
          for review by receiving entities, not an automatic enforcement order.
        </div>
      </div>
      <div class="summary-stack">
        <div class="detail-panel">
          <dl>
            <div>
              <dt>Brand Impersonated</dt>
              <dd>{{ report.ai_analysis.brand_impersonated or 'None identified' }}</dd>
            </div>
            <div>
              <dt>Resolved IPs</dt>
              <dd>{{ report.network_attribution.resolved_ips|length }}</dd>
            </div>
            <div>
              <dt>Holder-linked ASNs</dt>
              <dd>{{ report.network_attribution.holder_linked_asns|length }}</dd>
            </div>
            <div>
              <dt>Capture Status</dt>
              <dd>
                {% if primary_capture and primary_capture.http_status is not none %}
                  <span class="status-pill active">Active capture {{ primary_capture.http_status }}</span>
                {% else %}
                  <span class="status-pill down">No active response</span>
                {% endif %}
              </dd>
            </div>
          </dl>
        </div>
        <div class="note-box">
          <strong>Coordination note.</strong>
          This report is prepared to shorten review time for blocking, intermediary takedown, network coordination, or brand
          protection outreach by consolidating screenshots, hashes, attribution clues, and legal triage into one shareable record.
        </div>
      </div>
    </section>

    <section class="section-card" id="section-a">
      <p class="section-kicker">A. Executive Findings</p>
      <h2>Summary of observed activity</h2>
      <p class="section-intro">
        Concise statement of the observed activity, the suspected misuse pattern, and the main enforcement relevance.
      </p>
      <div class="grid-2">
        <div class="legal-panel">
          <table class="report-table">
            <tbody>
              <tr><th>Fraud mechanism</th><td>{{ report.ai_analysis.fraud_mechanism or 'Not assigned' }}</td></tr>
              <tr><th>Victim profile</th><td>{{ report.ai_analysis.victim_profile or 'Not assigned' }}</td></tr>
              <tr><th>Recommended action</th><td>{{ report.ai_analysis.recommended_action or 'Retain for review' }}</td></tr>
              <tr><th>Priority score</th><td>{{ report.ai_analysis.priority_score }}</td></tr>
            </tbody>
          </table>
        </div>
        <div class="note-box">
          <strong>Analytical narrative.</strong><br>
          {{ report.ai_analysis.illegal_activity_description }}
          <br><br>
          {% if report.payment_methods %}
            <strong>Detected payment rails:</strong> {{ report.payment_methods | map(attribute='method') | join(', ') }}.
          {% else %}
            <strong>Detected payment rails:</strong> No explicit payment or deposit indicators were extracted during this run.
          {% endif %}
        </div>
      </div>
    </section>

    <section class="section-card" id="section-b">
      <p class="section-kicker">B. Evidentiary Capture</p>
      <h2>Rendered website evidence</h2>
      <p class="section-intro">
        Screenshots are captured from controlled desktop and mobile browser profiles and hashed to support downstream integrity checks.
      </p>
      {% if capture_cards | selectattr('cloaking_suspected') | list %}
        <div class="note-box" style="margin-bottom: 16px;">
          <strong>Cloaking note.</strong> Desktop and mobile views differed materially, which may indicate profile-based content variation.
        </div>
      {% endif %}
      <div class="capture-grid">
        {% for card in capture_cards %}
          <article class="evidence-card">
            <div class="evidence-head">
              <span>{{ card.profile|replace('_', ' ')|title }}</span>
              <span>{{ card.http_status if card.http_status is not none else 'Capture failed' }}</span>
            </div>
            {% if card.viewport_data_uri %}
              <div class="evidence-frame">
                <img src="{{ card.viewport_data_uri }}" alt="{{ card.profile }} viewport screenshot" data-lightbox="{{ card.viewport_data_uri }}">
              </div>
            {% endif %}
            <div class="evidence-meta">
              {% if card.error %}
                <strong>Error:</strong> {{ card.error }}<br>
              {% endif %}
              {% if card.title %}
                <strong>Title:</strong> {{ card.title }}<br>
              {% endif %}
              {% if card.timestamp %}
                <strong>Timestamp:</strong> {{ card.timestamp }}<br>
              {% endif %}
              {% if card.viewport_hash %}
                <strong>Viewport SHA-256:</strong> {{ card.viewport_hash }}<br>
              {% endif %}
              {% if card.full_data_uri %}
                <div class="evidence-frame" style="margin-top: 12px;">
                  <img src="{{ card.full_data_uri }}" alt="{{ card.profile }} full-page screenshot" data-lightbox="{{ card.full_data_uri }}">
                </div>
                <div style="margin-top: 12px;">
                  <strong>Full-page SHA-256:</strong> {{ card.full_hash or 'Unavailable' }}
                </div>
              {% endif %}
            </div>
          </article>
        {% else %}
          <div class="note-box">
            No evidence capture records were available for this domain.
          </div>
        {% endfor %}
      </div>
    </section>

    <section class="section-card" id="section-c">
      <p class="section-kicker">C. Registration and Infrastructure</p>
      <h2>Registration context and DNS footprint</h2>
      <p class="section-intro">
        Registration metadata and resolved records help identify operational recency, registrar exposure, and the basic infrastructure footprint of the target.
      </p>
      <div class="grid-2">
        <div class="detail-panel">
          <table class="report-table">
            <tbody>
              <tr><th>Registrar</th><td>{{ report.registration.registrar or 'Unknown' }}</td></tr>
              <tr><th>Registration date</th><td>{{ report.registration.registered or 'Unknown' }}</td></tr>
              <tr><th>Expiry date</th><td>{{ report.registration.expires or 'Unknown' }}</td></tr>
              <tr><th>Registrant country</th><td>{{ report.registration.country or 'Unknown' }}</td></tr>
              <tr><th>Nameservers</th><td>{{ report.registration.nameservers|join(', ') if report.registration.nameservers else 'Unknown' }}</td></tr>
              <tr><th>Domain age</th><td>{{ domain_age.days ~ ' days' if domain_age.days is not none else 'Unknown' }}</td></tr>
            </tbody>
          </table>
          {% if domain_age.is_new_domain %}
            <div class="note-box" style="margin-top: 12px;">
              <strong>New-domain indicator.</strong> Registration age appears to be under 30 days.
            </div>
          {% endif %}
        </div>
        <div class="detail-panel">
          <table class="report-table">
            <tbody>
              {% for record_type, values in report.dns_records.items() %}
                <tr>
                  <th>{{ record_type }}</th>
                  <td>{{ values|join(', ') if values else 'No values returned' }}</td>
                </tr>
              {% else %}
                <tr><th>DNS</th><td>No DNS records were stored for this domain.</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="section-card" id="section-d">
      <p class="section-kicker">D. Threat Intelligence Corroboration</p>
      <h2>External-source verdicts</h2>
      <p class="section-intro">
        These source verdicts provide independent context. They should be interpreted together with the capture evidence rather than as a stand-alone conclusion.
      </p>
      <div class="grid-3">
        <div class="detail-panel"><strong>VirusTotal</strong><br>{{ report.threat_intel.vt_malicious }}/{{ report.threat_intel.vt_total }} malicious engines flagged</div>
        <div class="detail-panel"><strong>URLScan</strong><br>{{ report.threat_intel.urlscan_verdict or 'No verdict' }}{% if report.threat_intel.urlscan_score is not none %} · score {{ report.threat_intel.urlscan_score }}{% endif %}</div>
        <div class="detail-panel"><strong>URLhaus</strong><br>{{ 'Listed' if report.threat_intel.urlhaus_listed else 'Not listed' }}{% if report.threat_intel.urlhaus_threat %} · {{ report.threat_intel.urlhaus_threat }}{% endif %}</div>
        <div class="detail-panel"><strong>Google Safe Browsing</strong><br>{{ report.threat_intel.gsb_threats|join(', ') if report.threat_intel.gsb_threats else 'No blocklist threat returned' }}</div>
        <div class="detail-panel"><strong>AlienVault OTX</strong><br>{{ report.threat_intel.otx_pulse_count }} associated pulses</div>
        <div class="detail-panel"><strong>PhishTank / AbuseIPDB</strong><br>{{ 'Verified phishing listing' if report.threat_intel.phishtank_verified else 'No PhishTank verification' }}{% if report.threat_intel.abuseipdb_score is not none %} · Abuse score {{ report.threat_intel.abuseipdb_score }}{% endif %}</div>
      </div>
    </section>

    <section class="section-card" id="section-e">
      <p class="section-kicker">E. Payment and Transaction Signals</p>
      <h2>Observed payment-related indicators</h2>
      <p class="section-intro">
        Payment indicators are heuristic observations extracted from rendered content, accessible embedded frames, and network requests. They are useful for outreach and preservation, but they do not independently prove merchant-acquirer relationships.
      </p>
      <div class="grid-2">
        <div class="tech-panel">
          <ul class="key-list">
            {% for payment in report.payment_methods %}
              <li>
                <strong>{{ payment.method }}</strong>
                {% if payment.source %} from {{ payment.source }}{% endif %}
                {% if payment.evidence %}<br><span class="muted">{{ payment.evidence }}</span>{% endif %}
              </li>
            {% else %}
              <li>No payment method or deposit indicators were extracted in this run.</li>
            {% endfor %}
          </ul>
        </div>
        <div class="note-box">
          <strong>Why this section matters.</strong>
          Where present, these indicators can help receiving entities identify likely payment rails, examine intermediary exposure,
          preserve traces before content changes, and prioritise requests to processors, wallets, or platforms connected to the observed activity.
        </div>
      </div>
    </section>

    <section class="section-card" id="section-f">
      <p class="section-kicker">F. Preliminary Legal Mapping</p>
      <h2>Indicative statutory relevance</h2>
      <p class="section-intro">
        The following provisions are analyst-assigned triage references based on the observed evidence. They are intended to support review by legal, policy, or platform recipients and should not be treated as an executable order without further authority.
      </p>
      <table class="report-table">
        <thead>
          <tr>
            <th>Statute</th>
            <th>Offence</th>
            <th>Observed basis</th>
            <th>Confidence</th>
          </tr>
        </thead>
        <tbody>
          {% for law in report.ai_analysis.applicable_laws %}
            <tr>
              <td>{{ law.statute or law['statute'] }}</td>
              <td>{{ law.offence or law['offence'] }}</td>
              <td>{{ law.evidence or law['evidence'] }}</td>
              <td>{{ law.confidence or law['confidence'] }}</td>
            </tr>
          {% else %}
            <tr><td colspan="4">No specific statutory provisions were assigned by the analytical model for the present capture.</td></tr>
          {% endfor %}
        </tbody>
      </table>
      <div class="note-box" style="margin-top: 16px;">
        <strong>Legal interpretation note.</strong>
        The narrative below is intended to make the analytical basis legible to non-specialist recipients:
        <br><br>
        {{ report.ai_analysis.illegal_activity_description }}
      </div>
    </section>

    <section class="section-card" id="section-g">
      <p class="section-kicker">G. Attribution and Linkage</p>
      <h2>Network attribution and technical observations</h2>
      <p class="section-intro">
        APNIC enrichment provides allocation-level context for observed IP space. Holder-linked ASN entries reflect shared holder-name signals and should be read as allocation associations, not route-origin confirmation.
      </p>
      <div class="grid-2">
        <div class="tech-panel">
          <table class="report-table">
            <tbody>
              <tr><th>Primary allocation holder</th><td>{{ report.network_attribution.primary_holder or 'Unavailable' }}</td></tr>
              <tr><th>Primary region</th><td>{{ report.network_attribution.primary_economy_name or report.network_attribution.primary_cc or 'Unavailable' }}</td></tr>
              <tr><th>Resolved IP set</th><td>{{ report.network_attribution.resolved_ips|join(', ') if report.network_attribution.resolved_ips else 'No resolved IPs recorded' }}</td></tr>
              <tr><th>Capture status</th><td>{{ primary_capture.http_status if primary_capture else 'N/A' }}</td></tr>
              <tr><th>Capture URL used</th><td>{{ primary_capture.attempted_url if primary_capture else 'N/A' }}</td></tr>
              <tr><th>Redirect chain</th><td>{{ redirect_chain|join(' → ') if redirect_chain else 'No redirects recorded' }}</td></tr>
              <tr><th>Wayback snapshot</th><td>{% if wayback_snapshot.url %}<a href="{{ wayback_snapshot.url }}">Archived copy</a>{% else %}Not available{% endif %}</td></tr>
            </tbody>
          </table>

          {% if report.network_attribution.holder_linked_asns %}
            <h3 style="color: var(--text-strong); margin-bottom: 8px;">Holder-linked ASN allocations</h3>
            <ul class="key-list">
              {% for asn in report.network_attribution.holder_linked_asns %}
                <li>
                  <strong>{{ asn.resource }}</strong>
                  {% if asn.holder_name %} · {{ asn.holder_name }}{% endif %}
                  {% if asn.economy_name or asn.cc %}<br><span class="muted">{{ asn.economy_name or 'Unknown economy' }}{% if asn.cc %} ({{ asn.cc }}){% endif %}</span>{% endif %}
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>

        <div class="tech-panel">
          <table class="report-table">
            <thead>
              <tr>
                <th>IP</th>
                <th>Resource</th>
                <th>Holder</th>
                <th>Region</th>
              </tr>
            </thead>
            <tbody>
              {% for allocation in report.network_attribution.matched_allocations %}
                <tr>
                  <td>{{ allocation.ip_address }}</td>
                  <td>{{ allocation.resource }}</td>
                  <td>{{ allocation.holder_name or 'Unknown' }}</td>
                  <td>{{ allocation.economy_name or allocation.cc or 'Unknown' }}</td>
                </tr>
              {% else %}
                <tr><td colspan="4">No APNIC allocation rows matched the resolved IP set.</td></tr>
              {% endfor %}
            </tbody>
          </table>

          <div class="grid-2" style="margin-top: 16px;">
            {% if response_headers %}
              <div class="detail-panel">
                <h3 style="margin-top: 0; color: var(--text-strong);">Response headers</h3>
                <ul class="key-list">
                  {% for key, value in response_headers.items() %}
                    <li><strong>{{ key }}:</strong> {{ value }}</li>
                  {% endfor %}
                </ul>
              </div>
            {% endif %}
            {% if linked_domains %}
              <div class="detail-panel">
                <h3 style="margin-top: 0; color: var(--text-strong);">Linked domains</h3>
                <ul class="key-list">
                  {% for linked in linked_domains %}
                    <li>{{ linked }}</li>
                  {% endfor %}
                </ul>
              </div>
            {% endif %}
            {% if first_ten_certs %}
              <div class="detail-panel">
                <h3 style="margin-top: 0; color: var(--text-strong);">Certificate transparency sample</h3>
                <ul class="key-list">
                  {% for cert in first_ten_certs %}
                    <li><strong>{{ cert.name }}</strong>{% if cert.issuer %} · {{ cert.issuer }}{% endif %}</li>
                  {% endfor %}
                </ul>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </section>

    <section class="section-card" id="section-h">
      <p class="section-kicker">H. Coordination and Integrity</p>
      <h2>Recommended follow-up and evidence manifest</h2>
      <p class="section-intro">
        Use the manifest hashes below to verify that the report package and screenshots have not changed after receipt. This is especially useful when the report is forwarded across organisations or attached to follow-up communications.
      </p>
      <div class="grid-2">
        <div class="legal-panel">
          <table class="report-table">
            <tbody>
              <tr><th>Recommended action</th><td>{{ report.ai_analysis.recommended_action or 'Retain for supervisory review' }}</td></tr>
              <tr><th>Manifest hash</th><td>{{ report.evidence_manifest_hash or 'Unavailable' }}</td></tr>
              <tr><th>Final URL</th><td>{{ primary_capture.final_url if primary_capture else 'Unavailable' }}</td></tr>
              <tr><th>Capture quality score</th><td>{{ primary_capture.capture_quality_score if primary_capture else 'Unavailable' }}</td></tr>
            </tbody>
          </table>
          {% if pdf_generation_error %}
            <div class="note-box" style="margin-top: 12px;">
              <strong>PDF status:</strong> {{ pdf_generation_error }}
            </div>
          {% endif %}
        </div>
        <div class="note-box">
          <strong>Suggested receiving-entity handling.</strong>
          Use this package to review whether the observed content, infrastructure placement, or transaction indicators warrant intermediary action,
          platform review, network containment, or escalation to the appropriate legal and operational channel. Screenshots and hashes are included
          to preserve an evidentiary snapshot even if the website content changes later.
        </div>
      </div>
      <table class="report-table" style="margin-top: 16px;">
        <thead>
          <tr>
            <th>File</th>
            <th>Type</th>
            <th>Profile</th>
            <th>Timestamp</th>
            <th>SHA-256</th>
          </tr>
        </thead>
        <tbody>
          {% for item in manifest_entries %}
            <tr>
              <td>{{ item.file }}</td>
              <td>{{ item.type }}</td>
              <td>{{ item.profile }}</td>
              <td>{{ item.timestamp }}</td>
              <td>{{ item.hash }}</td>
            </tr>
          {% else %}
            <tr><td colspan="5">No manifest entries were generated for this report.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </section>
  </div>

  {% if not is_pdf %}
    <div class="lightbox" id="lightbox">
      <button type="button" aria-label="Close lightbox" onclick="window.closeReportLightbox()">×</button>
      <img alt="Expanded screenshot preview" id="lightbox-image">
    </div>

    <script>
      window.closeReportLightbox = function () {
        document.getElementById("lightbox").classList.remove("active");
      };
      document.querySelectorAll("[data-lightbox]").forEach(function (image) {
        image.addEventListener("click", function () {
          document.getElementById("lightbox-image").src = image.getAttribute("data-lightbox");
          document.getElementById("lightbox").classList.add("active");
        });
      });
      document.getElementById("lightbox").addEventListener("click", function (event) {
        if (event.target.id === "lightbox") {
          window.closeReportLightbox();
        }
      });
    </script>
  {% endif %}
</body>
</html>
